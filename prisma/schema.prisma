generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id              String           @id @default(uuid())
  name            String
  permissions     String[]         // Legacy — kept for backward compat during migration
  isSuperAdmin    Boolean          @default(false)
  isSystemRole    Boolean          @default(false)
  workers         Worker[]
  workerRoles     WorkerRole[]
  rolePermissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  module      String
  action      String
  description String?
  roles       RolePermission[]

  @@unique([module, action])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model WorkerRole {
  workerId   String
  roleId     String
  assignedBy String?
  assignedAt DateTime @default(now())
  worker     Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([workerId, roleId])
}

model Worker {
  id                     String               @id @default(uuid())
  workerId               String?
  legacyPasswordHash     String?              @map("legacy_password_hash")
  firstName              String
  lastName               String
  email                  String               @unique
  phone                  String
  roleId                 String?              // Optional — legacy FK, use WorkerRole going forward
  status                 String
  avatarUrl              String
  majorMinistryId        String
  minorMinistryId        String
  subMinistryId          String?              // Team Leader scope — sub-ministry this flag applies to
  flags                  String[]             @default([]) // team_leader, ministry_scheduler, mentor, hr, room_reservation_manager
  institutionFlag        Boolean              @default(false) // auto-set when employmentType is Full Time or On-call
  employmentType         String?
  birthDate              String?
  passwordChangeRequired Boolean              @default(false)
  qrToken                String?
  isSeniorPastor         Boolean              @default(false)
  address                String?
  biometricsId           Int?
  startMonth             String?
  startYear              String?
  remarks                String?
  legacyMigratedAt       DateTime?
  legacyMigratedFrom     String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @default(now()) @updatedAt
  @@index([workerId])
  @@index([majorMinistryId])
  @@index([minorMinistryId])
  @@index([status])
  roles                  WorkerRole[]
  approvals              ApprovalRequest[]
  attendanceRecords      AttendanceRecord[]
  bookings               Booking[]
  venueBookings          VenueBooking[]       @relation("WorkerVenueBookings")
  InventoryBorrowing     InventoryBorrowing[] @relation("WorkerBorrowings")
  InventoryLog           InventoryLog[]       @relation("WorkerLogs")
  mealStubs              MealStub[]
  role                   Role?                @relation(fields: [roleId], references: [id])
  capabilities           String[]             @default([])
  masterSchedule         MasterSchedule?
  masterScheduleOverrides MasterScheduleOverride[]
}

model Ministry {
  id                  String     @id @default(uuid())
  name                String
  description         String
  departmentCode      String
  leaderId            String
  headId              String?
  approverId          String?
  schedulerIds        String[]   @default([])
  mealStubAssignerId  String?
  mealStubWeeklyLimit Int?
  weight              Int?
  department          Department @relation(fields: [departmentCode], references: [code])
  managerId           String?
  categories          WorkloadCategory[]

  @@index([departmentCode])
}

model Department {
  code       String     @id
  name       String     @unique
  weight     Int
  ministries Ministry[]
}

model AttendanceRecord {
  id              String   @id @default(uuid())
  workerProfileId String
  type            String
  time            DateTime @default(now())
  isLate          Boolean  @default(false)
  lateMinutes     Int?
  worker          Worker   @relation(fields: [workerProfileId], references: [id])

  @@index([workerProfileId, time])
}

// HR-editable per-worker shift schedule (5.10.1) — drives late-flagging on
// Clock In and the FT/OC weekday meal stub allocation's "days off" exclusion.
model MasterSchedule {
  id            String   @id @default(cuid())
  workerId      String   @unique
  worker        Worker   @relation(fields: [workerId], references: [id])
  shiftStart    String   // "HH:mm" 24h
  shiftEnd      String   // "HH:mm" 24h
  daysOff       Int[]    @default([0]) // 0=Sunday..6=Saturday
  effectiveFrom DateTime @default(now())
  updatedBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Per-date overrides to a worker's MasterSchedule — written by approved
// ChangeTime/ChangeDayOff leave requests (5.10.4) so that date doesn't get a
// false late flag or incorrect weekday stub allocation.
model MasterScheduleOverride {
  id         String   @id @default(cuid())
  workerId   String
  worker     Worker   @relation(fields: [workerId], references: [id])
  date       DateTime
  shiftStart String?
  shiftEnd   String?
  isDayOff   Boolean  @default(false)
  reason     String?
  sourceType String?
  sourceId   String?
  createdAt  DateTime @default(now())

  @@unique([workerId, date])
  @@index([workerId])
}

// Global HR-configurable grace period for late-flagging.
model AttendanceSetting {
  id                 String   @id @default("global")
  gracePeriodMinutes Int      @default(15)
  updatedBy          String?
  updatedAt          DateTime @updatedAt
}

model Booking {
  id                 String    @id @default(uuid())
  requestId          String?
  roomId             String
  title              String
  purpose            String?
  start              DateTime
  end                DateTime
  status             String
  workerProfileId    String
  name               String
  ministryId         String
  email              String
  requesterEmail     String?
  dateRequested      DateTime  @default(now())
  pax                Int
  numTables          Int?
  numChairs          Int?
  equipment_TV       Boolean   @default(false)
  equipment_Mic      Boolean   @default(false)
  equipment_Speakers Boolean   @default(false)
  requestedElements  String[]
  guidelinesAccepted Boolean
  checkedInAt        DateTime?
  room               Room      @relation(fields: [roomId], references: [id])
  worker             Worker    @relation(fields: [workerProfileId], references: [id])
}

model Room {
  id                     String                    @id @default(uuid())
  name                   String
  capacity               Int
  elements               String[]
  areaId                 String
  weight                 Int?
  bookings               Booking[]
  eventBookings          EventRoomBooking[]
  venueBookings          VenueBooking[]            @relation("RoomVenueBookings")
  assistanceConfigurations AssistanceConfiguration[] @relation("RoomAssistanceConfigs")
  displayDevices         RoomDisplayDevice[]
  area                   Area                      @relation(fields: [areaId], references: [id])
}

// Room Display Monitor (SRD 5.8.3): a registered kiosk/tablet that shows a
// single room's schedule. Identified by an opaque token in the URL
// (?token=...) — no worker login required. Sys Admin assigns a device to a
// room from Settings > Rooms > Displays.
model RoomDisplayDevice {
  id         String    @id @default(uuid())
  name       String
  token      String    @unique
  roomId     String?
  room       Room?     @relation(fields: [roomId], references: [id], onDelete: SetNull)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
}

model Area {
  id       String  @id @default(uuid())
  areaId   String?
  name     String
  branchId String
  branch   Branch  @relation(fields: [branchId], references: [id])
  rooms    Room[]
}

model Branch {
  id    String @id @default(uuid())
  name  String
  areas Area[]
}

model MealStub {
  id             String    @id @default(uuid())
  workerId       String
  workerName     String
  scheduleId     String?
  date           DateTime
  status         String
  stubType       String?
  assignedBy     String?
  assignedByName String?
  claimedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
  worker         Worker    @relation(fields: [workerId], references: [id])

  @@index([workerId, scheduleId])
}

model VenueElement {
  id                 String @id @default(uuid())
  name               String
  category           String
  providerMinistryId String
}

model ApprovalRequest {
  id               String   @id @default(uuid())
  requester        String
  type             String
  details          String
  date             DateTime @default(now())
  status           String
  workerId         String?
  roomId           String?
  reservationId    String?
  requestId        String?
  oldMajorId       String?
  newMajorId       String?
  oldMinorId       String?
  newMinorId       String?
  outgoingApproved Boolean?
  incomingApproved Boolean?
  worker           Worker?  @relation(fields: [workerId], references: [id])
}

model ScanLog {
  id             String   @id @default(uuid())
  scannerId      String
  scannerName    String
  timestamp      DateTime @default(now())
  scanType       String
  details        String
  targetUserId   String?
  targetUserName String?
  mealStubId     String?
  reservationId  String?
}

model C2SMentee {
  id        String   @id @default(uuid())
  firstName String
  lastName  String
  email     String
  phone     String
  status    String
  groupId   String
  mentorId  String
  createdAt DateTime @default(now())
  group     C2SGroup @relation(fields: [groupId], references: [id])
}

model C2SGroup {
  id        String      @id @default(uuid())
  name      String
  mentorId  String
  menteeIds String[]
  createdAt DateTime    @default(now())
  mentees   C2SMentee[]
}

model Setting {
  id   String @id
  data Json
}

model DepartmentSetting {
  id                        String  @id
  headId                    String?
  description               String?
  mealStubWeekdayAllocation Int     @default(0)
  mealStubSundayAllocation  Int     @default(0)
}

model TransactionLog {
  id         String   @id @default(uuid())
  userId     String?
  userEmail  String?
  userName   String?
  action     String
  module     String
  details    String?
  targetId   String?
  targetName String?
  // Layer 4 (generic audit log) additions — before/after state snapshots and
  // a free-text reason, e.g. for approval rejections or RBAC/role changes.
  before     Json?
  after      Json?
  reason     String?
  timestamp  DateTime @default(now())
}

model InventoryCategory {
  id          String          @id @default(uuid())
  name        String          @unique
  description String?
  color       String?
  icon        String?
  group       String?
  isActive    Boolean         @default(true)
  items       InventoryItem[]
}

model InventoryItem {
  id                  String               @id @default(uuid())
  type                InventoryType        @default(EQUIPMENT)
  weight              Int?
  group               String?
  categoryId          String
  inventoryCode       String?              @unique
  name                String
  role                String?
  location            String?
  aisle               String?
  shelf               String?
  bin                 String?
  assignedTo          String?
  purchaseDate        String?
  expiryDate          DateTime?
  nextMaintenanceDate DateTime?
  parentId            String?
  isApprovalRequired  Boolean              @default(false)
  statusCode          Int?
  status              String?              @default("Good Condition")
  statusDetails       String?
  recommendation      String?
  quantity            Int                  @default(0)
  minQuantity         Int                  @default(0)
  reorderLevel        Int?
  unit                String               @default("pcs")
  imageUrl            String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  borrowings          InventoryBorrowing[]
  category            InventoryCategory    @relation(fields: [categoryId], references: [id])
  parent              InventoryItem?       @relation("ItemBundles", fields: [parentId], references: [id])
  children            InventoryItem[]      @relation("ItemBundles")
  logs                InventoryLog[]
  eventEquipment      EventEquipment[]
}

model InventoryBorrowing {
  id                String        @id @default(uuid())
  itemId            String
  borrowerId        String
  borrowedAt        DateTime      @default(now())
  dueDate           DateTime?
  returnedAt        DateTime?
  status            String        @default("BORROWED")
  checkoutNotes     String?
  checkoutCondition String?
  checkoutChecklist Json?
  returnNotes       String?
  returnCondition   String?
  returnChecklist   Json?
  returnPhotos      String[]
  borrower          Worker        @relation("WorkerBorrowings", fields: [borrowerId], references: [id])
  item              InventoryItem @relation(fields: [itemId], references: [id])
}

model InventoryLog {
  id        String        @id @default(uuid())
  itemId    String
  workerId  String?
  type      String
  quantity  Int
  balance   Int
  notes     String?
  timestamp DateTime      @default(now())
  item      InventoryItem @relation(fields: [itemId], references: [id])
  worker    Worker?       @relation("WorkerLogs", fields: [workerId], references: [id])
}

enum InventoryType {
  EQUIPMENT
  CONSUMABLE
}

model VenueBooking {
  id                 String              @id @default(cuid())
  requestId          String              @unique
  roomId             String
  room               Room                @relation("RoomVenueBookings", fields: [roomId], references: [id])
  workerProfileId    String
  worker             Worker              @relation("WorkerVenueBookings", fields: [workerProfileId], references: [id])
  title              String
  purpose            String?
  start              DateTime
  end                DateTime
  status             String              @default("Pending Ministry Approval")
  pax                Int                 @default(0)
  numTables          Int                 @default(0)
  numChairs          Int                 @default(0)
  guidelinesAccepted Boolean             @default(false)
  recurringBookingId String?
  recurringBooking   RecurringBooking?   @relation(fields: [recurringBookingId], references: [id])
  assistanceRequests AssistanceRequest[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model RecurringBooking {
  id              String         @id @default(cuid())
  roomId          String
  workerProfileId String
  title           String
  purpose         String?
  recurrenceRule  String
  startTime       String
  endTime         String
  startDate       DateTime
  endDate         DateTime?
  pax             Int            @default(0)
  status          String         @default("Active")
  occurrences     VenueBooking[]
  createdAt       DateTime       @default(now())
}


model WorkloadCategory {
  id          String   @id @default(uuid())
  ministryId  String
  ministry    Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  name        String
  description String?  @db.VarChar(255)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([ministryId, name])
  @@index([ministryId, sortOrder])
}


model AssistanceConfiguration {
  id         String                 @id @default(cuid())
  roomId     String
  room       Room                   @relation("RoomAssistanceConfigs", fields: [roomId], references: [id])
  ministryId String
  items      AssistanceConfigItem[]
  createdBy  String
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt

  @@unique([roomId, ministryId])
}

model AssistanceConfigItem {
  id          String                  @id @default(cuid())
  configId    String
  config      AssistanceConfiguration @relation(fields: [configId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Int                     @default(1)
  isRequired  Boolean                 @default(true)
}

model AssistanceRequest {
  id             String                  @id @default(cuid())
  bookingId      String
  booking        VenueBooking            @relation(fields: [bookingId], references: [id])
  ministryId     String
  status         String                  @default("Pending")
  explanation    String?
  respondedAt    DateTime?
  respondedBy    String?
  slaEscalatedAt DateTime?
  items          AssistanceRequestItem[]
  auditLogs      VenueAuditLog[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model AssistanceRequestItem {
  id           String            @id @default(cuid())
  requestId    String
  request      AssistanceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  quantity     Int               @default(1)
  isRequired   Boolean           @default(true)
  status       String            @default("Pending")
  adjustedQty  Int?
  adjustedDesc String?
}

model VenueAuditLog {
  id            String             @id @default(cuid())
  requestId     String?
  request       AssistanceRequest? @relation(fields: [requestId], references: [id])
  configId      String?
  action        String
  actorId       String
  before        Json?
  after         Json?
  triggerSource String?
  createdAt     DateTime           @default(now())
}

model VenueAssistanceSetting {
  id        String   @id @default("global")
  slaDays   Int      @default(3)
  updatedBy String?
  updatedAt DateTime @updatedAt
}

model InAppNotification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ── Worship Slots ─────────────────────────────────────────────────────────────

model WorshipSlot {
  id         String              @id @default(uuid())
  scheduleId String
  schedule   ServiceSchedule     @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  ministryId String?
  slotName   String
  isTws      Boolean             @default(false)
  order      Int                 @default(0)
  notes      String?
  createdAt  DateTime            @default(now())
  workers    WorshipSlotWorker[]

  @@index([scheduleId])
}

model WorshipSlotWorker {
  id         String      @id @default(uuid())
  slotId     String
  slot       WorshipSlot @relation(fields: [slotId], references: [id], onDelete: Cascade)
  workerId   String
  workerName String
  role       String?     // optional role label within the slot
  createdAt  DateTime    @default(now())

  @@index([slotId])
}

// ── Sunday Service Scheduling ─────────────────────────────────────────────────

model ServiceSchedule {
  id          String               @id @default(uuid())
  date        DateTime
  title       String               @default("Sunday Service")
  notes       String?
  status      String               @default("Draft") // Draft | Published | Completed
  isPublic    Boolean              @default(false)
  publicToken String?              @unique
  createdBy   String
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  assignments  ScheduleAssignment[]
  worshipSlots WorshipSlot[]
}

model ServiceTemplate {
  id         String         @id @default(uuid())
  ministryId String
  name       String         // e.g. "Standard Sunday", "Special Service"
  isDefault  Boolean        @default(false)
  createdBy  String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  roles      TemplateRole[]
}

model TemplateRole {
  id         String          @id @default(uuid())
  templateId String
  template   ServiceTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  roleName   String          // e.g. "Worship Leader", "Sound Engineer"
  count      Int             @default(1) // How many workers needed for this role
  notes      String?
  order      Int             @default(0)
}

model ScheduleAssignment {
  id               String          @id @default(uuid())
  scheduleId       String
  schedule         ServiceSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  ministryId       String
  roleName         String
  workerId         String?
  workerName       String?
  notes            String?
  rehearsalDate    DateTime?
  rehearsalTime    String?
  order            Int             @default(0)
  acknowledgedAt   DateTime?
  acknowledgedBy   String?
  attendanceStatus String          @default("Pending") // Pending | Confirmed | Not Attending
  createdAt        DateTime        @default(now())

  @@index([scheduleId])
  @@index([ministryId])
}

// ── Events Management ────────────────────────────────────────────────────────

model ChurchEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  date        DateTime
  endDate     DateTime?
  startTime   String?
  endTime     String?
  location    String?
  status      String   @default("Planning") // Planning | Confirmed | Ongoing | Completed | Cancelled
  createdBy   String
  notes       String?
  scheduleId  String?  // optional link to a ServiceSchedule
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rooms       EventRoomBooking[]
  assignments EventAssignment[]
  equipment   EventEquipment[]

  @@index([date])
  @@index([status])
}

model EventRoomBooking {
  id        String      @id @default(uuid())
  eventId   String
  event     ChurchEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  roomId    String
  room      Room        @relation(fields: [roomId], references: [id])
  startTime String      // "HH:MM" local time
  endTime   String
  purpose   String?
  notes     String?

  @@index([eventId])
  @@index([roomId])
}

model EventAssignment {
  id         String      @id @default(uuid())
  eventId    String
  event      ChurchEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ministryId String
  roleName   String
  workerId   String?
  workerName String?
  notes      String?
  order      Int         @default(0)

  @@index([eventId])
  @@index([ministryId])
}

model EventEquipment {
  id          String        @id @default(uuid())
  eventId     String
  event       ChurchEvent   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id])
  quantity    Int           @default(1)
  notes       String?

  @@index([eventId])
  @@index([itemId])
}

// ── Generic Approval Workflow Engine (Layer 2) ──────────────────────────────
// Reusable multi-stage approval state machine shared by Room Reservation,
// Major Event Requests, Leave/Request filing, Minor Ministry assignment, etc.
// New workflow types are added by passing a different stage template to
// createWorkflow() — no schema changes needed. See
// apps/web/src/services/approval-engine.ts.

model ApprovalWorkflow {
  id          String          @id @default(cuid())
  type        String
  subjectId   String
  requesterId String
  status      String          @default("Pending")
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  stages      ApprovalStage[]

  @@index([type, subjectId])
  @@index([requesterId])
}

model ApprovalStage {
  id            String           @id @default(cuid())
  workflowId    String
  workflow      ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  stageOrder    Int
  // Stages sharing a parallelGroup are all active at once and must all be
  // decided before the workflow advances past the group (e.g. Major Event's
  // per-ministry approval stages).
  parallelGroup Int?
  // { kind: 'worker', workerId } | { kind: 'permission', module, action }
  // | { kind: 'ministryRole', ministryId, role: 'head'|'manager'|'approver'|'scheduler' }
  approverSpec  Json
  status        String           @default("Pending")
  decidedBy     String?
  decidedAt     DateTime?
  reason        String?
  createdAt     DateTime         @default(now())

  @@index([workflowId, status])
}

// ── Major Event Requests (SRD 5.11) ──────────────────────────────────────────
//
// A cross-ministry event request built from a Sys-Admin-managed service
// catalogue (grouped by providing ministry). Approval runs on the generic
// engine above: one parallel-group stage per providing ministry's Ministry
// Head, followed by a sequential Admin Dept Head final stage. ministryId /
// requesterId / catalogItemId are soft references (matching
// ApprovalWorkflow.subjectId / requesterId and AssistanceConfiguration.ministryId)
// — no Prisma relation, to avoid growing the Worker/Ministry models.

model MajorEventServiceCatalogItem {
  id          String   @id @default(cuid())
  ministryId  String
  name        String
  description String?
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([ministryId])
}

model MajorEventRequest {
  id          String                  @id @default(cuid())
  title       String
  description String?
  eventDate   DateTime
  endDate     DateTime?
  location    String?
  requesterId String
  ministryId  String
  status      String                  @default("Pending")
  items       MajorEventRequestItem[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([requesterId])
  @@index([ministryId])
}

model MajorEventRequestItem {
  id            String            @id @default(cuid())
  requestId     String
  request       MajorEventRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  catalogItemId String?
  // Providing ministry — drives which parallel approval stage this item belongs to.
  ministryId    String
  name          String
  notes         String?
  quantity      Int?
  // Synced from the providing ministry's parallel stage decision: Pending | Approved | Declined.
  status        String            @default("Pending")

  @@index([requestId])
  @@index([ministryId])
}

// Sys Admin toggle for enabling/disabling the Major Event request button (SA3).
model MajorEventSetting {
  id        String   @id @default("global")
  enabled   Boolean  @default(true)
  updatedBy String?
  updatedAt DateTime @updatedAt
}
