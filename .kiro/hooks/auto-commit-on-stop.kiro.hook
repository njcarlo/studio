{
  "enabled": true,
  "name": "Auto Commit & Push",
  "description": "Automatically stages all changes, commits with a timestamp message, and pushes to origin after Kiro finishes working",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A && git diff --cached --quiet || git commit -m \"kiro: auto-commit $(date +%Y-%m-%d\\ %H:%M:%S)\" && git push"
  }
}