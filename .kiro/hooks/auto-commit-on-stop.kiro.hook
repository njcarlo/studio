{
  "enabled": true,
  "name": "Auto Commit & Push",
  "description": "Stages all changes, generates a commit message from changed files, and pushes to origin after Kiro finishes working",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "git add -A; $f = (git diff --cached --name-only) -join ', '; if ($f) { git commit -m \"kiro: $f\"; git push }"
  }
}
