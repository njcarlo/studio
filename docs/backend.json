{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user account in the system.",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "roleId": { "type": "string", "description": "A reference to the user's role in the 'roles' collection." },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Pending Approval"] },
        "avatarUrl": { "type": "string", "format": "uri" },
        "primaryMinistryId": { "type": "string" },
        "secondaryMinistryId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "email", "roleId", "status", "createdAt"]
    },
    "Role": {
      "title": "Role",
      "type": "object",
      "description": "Defines a role with a set of privileges.",
      "properties": {
        "name": { "type": "string" },
        "privileges": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": ["name", "privileges"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profile information. Document ID should match the Firebase Auth UID."
    },
    "/roles/{roleId}": {
      "schema": { "$ref": "#/entities/Role" },
      "description": "Stores role definitions and associated privileges."
    }
  }
}
