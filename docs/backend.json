{
  "entities": {
    "Worker": {
      "title": "Worker",
      "type": "object",
      "description": "Represents a worker account in the system.",
      "properties": {
        "workerId": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "roleId": { "type": "string", "description": "A reference to the user's role in the 'roles' collection." },
        "status": { "type": "string", "enum": ["Active", "Inactive", "Pending Approval"] },
        "avatarUrl": { "type": "string", "format": "uri" },
        "primaryMinistryId": { "type": "string" },
        "secondaryMinistryId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["firstName", "lastName", "email", "roleId", "status", "createdAt"]
    },
    "Role": {
      "title": "Role",
      "type": "object",
      "description": "Defines a role within the system.",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Ministry": {
      "title": "Ministry",
      "type": "object",
      "description": "Defines a ministry within the church.",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "department": { "type": "string" },
        "leaderId": { "type": "string" }
      },
      "required": ["name", "department"]
    },
    "Branch": {
      "title": "Branch",
      "type": "object",
      "description": "A physical branch, location, or building.",
      "properties": {
        "name": { "type": "string" }
      },
      "required": ["name"]
    },
    "Room": {
      "title": "Room",
      "type": "object",
      "description": "A bookable room within a location.",
      "properties": {
        "name": { "type": "string" },
        "capacity": { "type": "number" },
        "equipment": { "type": "array", "items": { "type": "string" } },
        "branchId": { "type": "string" }
      },
      "required": ["name", "capacity", "branchId"]
    },
    "Reservation": {
      "title": "Reservation",
      "type": "object",
      "description": "A booking for a room.",
      "properties": {
        "roomId": { "type": "string" },
        "title": { "type": "string" },
        "start": { "type": "string", "format": "date-time" },
        "end": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "workerProfileId": { "type": "string" }
      },
      "required": ["roomId", "title", "start", "end", "status", "workerProfileId"]
    },
    "ApprovalRequest": {
      "title": "Approval Request",
      "type": "object",
      "description": "A request that requires admin approval.",
      "properties": {
        "requester": { "type": "string" },
        "type": { "type": "string" },
        "details": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Pending", "Approved", "Rejected"] },
        "workerId": { "type": "string" },
        "roomId": { "type": "string" },
        "reservationId": { "type": "string" }
      },
      "required": ["requester", "type", "details", "date", "status"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "type": "object",
      "description": "A record of a user clocking in or out.",
      "properties": {
        "workerProfileId": { "type": "string" },
        "type": { "type": "string", "enum": ["Clock In", "Clock Out"] },
        "time": { "type": "string", "format": "date-time" }
      },
      "required": ["workerProfileId", "type", "time"]
    },
    "MealStub": {
      "title": "Meal Stub",
      "type": "object",
      "description": "A voucher for a meal.",
      "properties": {
        "workerId": { "type": "string" },
        "workerName": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["Issued", "Claimed"] }
      },
      "required": ["workerId", "date", "status"]
    },
    "ScanLog": {
      "title": "Scan Log",
      "type": "object",
      "description": "A record of a QR code scan event.",
      "properties": {
        "scannerId": { "type": "string", "description": "The UID of the user operating the scanner." },
        "scannerName": { "type": "string", "description": "The name of the user operating the scanner." },
        "timestamp": { "type": "string", "format": "date-time" },
        "scanType": { "type": "string", "enum": ["Attendance", "Meal Stub", "Room Check-in"] },
        "details": { "type": "string", "description": "A human-readable summary of the scan event." },
        "targetUserId": { "type": "string", "description": "The UID of the user who was the subject of the scan (e.g., for attendance)." },
        "targetUserName": { "type": "string" },
        "mealStubId": { "type": "string" },
        "reservationId": { "type": "string" }
      },
      "required": ["scannerId", "scannerName", "timestamp", "scanType", "details"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/workers/{userId}": {
      "schema": { "$ref": "#/entities/Worker" },
      "description": "Stores worker profile information. Document ID should match the Firebase Auth UID."
    },
    "/roles/{roleId}": {
      "schema": { "$ref": "#/entities/Role" },
      "description": "Stores role definitions and associated privileges."
    },
    "/ministries/{ministryId}": {
      "schema": { "$ref": "#/entities/Ministry" },
      "description": "Stores ministry information."
    },
    "/branches/{branchId}": {
      "schema": { "$ref": "#/entities/Branch" },
      "description": "Stores branch information."
    },
    "/rooms/{roomId}": {
      "schema": { "$ref": "#/entities/Room" },
      "description": "Stores room information."
    },
    "/rooms/{roomId}/reservations/{reservationId}": {
      "schema": { "$ref": "#/entities/Reservation" },
      "description": "Stores room booking reservations."
    },
    "/approvals/{approvalId}": {
      "schema": { "$ref": "#/entities/ApprovalRequest" },
      "description": "Stores approval requests for various actions."
    },
    "/attendance_records/{recordId}": {
      "schema": { "$ref": "#/entities/AttendanceRecord" },
      "description": "Stores user attendance clock-in/out records."
    },
    "/mealstubs/{stubId}": {
      "schema": { "$ref": "#/entities/MealStub" },
      "description": "Stores meal stub information for users."
    },
    "/scan_logs/{logId}": {
      "schema": { "$ref": "#/entities/ScanLog" },
      "description": "Stores a log of all QR code scan events."
    }
  }
}
