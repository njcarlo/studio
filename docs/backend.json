{
  "entities": {
    "WorkerProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "WorkerProfile",
      "type": "object",
      "description": "Represents a worker's profile with personal details, roles, and permissions.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The full name of the worker."
        },
        "email": {
          "type": "string",
          "description": "The email address of the worker.",
          "format": "email"
        },
        "phone": {
          "type": "string",
          "description": "The phone number of the worker."
        },
        "role": {
          "type": "string",
          "description": "The role of the worker within the organization."
        },
        "permissions": {
          "type": "array",
          "description": "A list of permissions granted to the worker.",
          "items": {
            "type": "string"
          }
        },
        "status": {
            "type": "string",
            "description": "The current status of the worker's profile."
        },
        "avatarUrl": {
            "type": "string",
            "description": "URL for the worker's avatar image."
        }
      },
      "required": [
        "name",
        "email",
        "role",
        "permissions",
        "status"
      ]
    },
    "Approval": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Approval",
      "type": "object",
      "description": "Represents an approval record for worker registrations or profile updates.",
      "properties": {
        "requester": {
            "type": "string",
            "description": "Name of the person requesting the approval."
        },
        "type": {
            "type": "string",
            "description": "The type of approval request (e.g., 'New Worker', 'Room Booking')."
        },
        "details": {
            "type": "string",
            "description": "Details about the approval request."
        },
        "date": {
          "type": "string",
          "description": "The date and time when the approval was requested.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "The current status of the approval (e.g., 'pending', 'approved', 'rejected')."
        }
      },
      "required": [
        "requester",
        "type",
        "details",
        "date",
        "status"
      ]
    },
    "Room": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Room",
      "type": "object",
      "description": "Represents a room that can be reserved.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the room."
        },
        "capacity": {
          "type": "number",
          "description": "The maximum capacity of the room."
        },
        "equipment": {
          "type": "array",
          "description": "A list of equipment available in the room.",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "name",
        "capacity",
        "equipment"
      ]
    },
    "Equipment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Equipment",
      "type": "object",
      "description": "Represents a piece of equipment that can be borrowed.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the equipment."
        },
        "description": {
          "type": "string",
          "description": "A description of the equipment."
        },
        "available": {
          "type": "boolean",
          "description": "Indicates whether the equipment is currently available."
        }
      },
      "required": [
        "name",
        "available"
      ]
    },
    "Reservation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Reservation",
      "type": "object",
      "description": "Represents a reservation for a room.",
      "properties": {
        "roomId": {
          "type": "string",
          "description": "Reference to Room. (Relationship: Room 1:N Reservation)"
        },
        "workerProfileId": {
          "type": "string",
          "description": "Reference to WorkerProfile. (Relationship: WorkerProfile 1:N Reservation)"
        },
        "start": {
          "type": "string",
          "description": "The start date and time of the reservation.",
          "format": "date-time"
        },
        "end": {
          "type": "string",
          "description": "The end date and time of the reservation.",
          "format": "date-time"
        },
        "title": {
            "type": "string",
            "description": "The purpose or title of the reservation."
        },
        "status": {
            "type": "string",
            "description": "The approval status of the reservation."
        }
      },
      "required": [
        "roomId",
        "workerProfileId",
        "start",
        "end",
        "title",
        "status"
      ]
    },
    "Mealstub": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Mealstub",
      "type": "object",
      "description": "Represents a mealstub generated for a worker.",
      "properties": {
        "workerId": {
          "type": "string",
          "description": "Reference to WorkerProfile. (Relationship: WorkerProfile 1:N Mealstub)"
        },
        "workerName": {
            "type": "string"
        },
        "date": {
          "type": "string",
          "description": "The date when the mealstub was generated.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "The status of the mealstub (e.g., 'Issued', 'Claimed')."
        }
      },
      "required": [
        "workerId",
        "workerName",
        "date",
        "status"
      ]
    },
    "AttendanceRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AttendanceRecord",
      "type": "object",
      "description": "Represents an attendance record for a worker.",
      "properties": {
        "workerProfileId": {
          "type": "string",
          "description": "Reference to WorkerProfile. (Relationship: WorkerProfile 1:N AttendanceRecord)"
        },
        "type": {
            "type": "string"
        },
        "time": {
          "type": "string",
          "description": "The date and time when the worker clocked in or out.",
          "format": "date-time"
        }
      },
      "required": [
        "workerProfileId",
        "type",
        "time"
      ]
    },
     "Ministry": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Ministry",
      "type": "object",
      "description": "Represents a ministry within the church.",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the ministry."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the ministry's purpose."
        },
        "leaderId": {
          "type": "string",
          "description": "The ID of the worker who leads the ministry."
        },
        "type": {
          "type": "string",
          "enum": ["Primary", "Secondary"],
          "description": "The type of ministry."
        },
        "memberIds": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "A list of worker IDs who are members of the ministry."
        }
      },
      "required": ["name", "description", "leaderId", "type", "memberIds"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/worker_profiles/{workerProfileId}",
        "definition": {
          "entityName": "WorkerProfile",
          "schema": {
            "$ref": "#/entities/WorkerProfile"
          },
          "description": "Stores worker profile information. Document ID should match the Firebase Auth UID."
        }
      },
      {
        "path": "/approvals/{approvalId}",
        "definition": {
          "entityName": "Approval",
          "schema": {
            "$ref": "#/entities/Approval"
          },
          "description": "Stores all approval requests from across the application."
        }
      },
      {
        "path": "/rooms/{roomId}",
        "definition": {
          "entityName": "Room",
          "schema": {
            "$ref": "#/entities/Room"
          },
          "description": "Stores room information."
        }
      },
      {
        "path": "/rooms/{roomId}/reservations/{reservationId}",
        "definition": {
          "entityName": "Reservation",
          "schema": {
            "$ref": "#/entities/Reservation"
          },
          "description": "Stores reservation information for rooms."
        }
      },
      {
        "path": "/mealstubs/{mealstubId}",
        "definition": {
          "entityName": "Mealstub",
          "schema": {
            "$ref": "#/entities/Mealstub"
          },
          "description": "Stores mealstub information."
        }
      },
      {
        "path": "/attendance_records/{attendanceRecordId}",
        "definition": {
          "entityName": "AttendanceRecord",
          "schema": {
            "$ref": "#/entities/AttendanceRecord"
          },
          "description": "Stores attendance records for workers."
        }
      },
      {
        "path": "/equipment/{equipmentId}",
        "definition": {
          "entityName": "Equipment",
          "schema": {
            "$ref": "#/entities/Equipment"
          },
          "description": "Stores general information about equipment."
        }
      },
      {
        "path": "/ministries/{ministryId}",
        "definition": {
          "entityName": "Ministry",
          "schema": {
            "$ref": "#/entities/Ministry"
          },
          "description": "Stores information about ministries."
        }
      }
    ],
    "reasoning": "The Firestore data structure has been updated to better support the COGApp's features. A top-level `/approvals` collection has been added to centralize all approval workflows, simplifying the logic for the approvals page. A new top-level `/ministries` collection has been introduced to store ministry data. Worker profiles remain as a top-level collection where the document ID is the worker's authentication UID, which is a robust way to link authentication with user data and secure it with ownership-based rules."
  }
}
