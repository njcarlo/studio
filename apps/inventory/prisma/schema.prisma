generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  color       String?
  icon        String?
  isActive    Boolean @default(true)
  items       Item[]
}

model Location {
  id    String @id @default(cuid())
  name  String @unique
  items Item[]
}

model Item {
  id                  String    @id @default(cuid())
  name                String
  inventoryCode       String?   @unique
  categoryId          String
  type                String    @default("Equipment")
  stock               Int       @default(0)
  minStock            Int       @default(0)
  unit                String    @default("pcs")
  status              String    @default("Good Condition")
  statusDetails       String?
  locationId          String?
  aisle               String?
  shelf               String?
  bin                 String?
  assignedTo          String?
  imageUrl            String?
  isApprovalRequired  Boolean   @default(false)
  isKit               Boolean   @default(false)
  nextMaintenanceDate DateTime?
  parentId            String?
  lastUpdated         DateTime  @default(now()) @updatedAt
  createdAt           DateTime  @default(now())

  category    Category          @relation(fields: [categoryId], references: [id])
  location    Location?         @relation(fields: [locationId], references: [id])
  parent      Item?             @relation("KitItems", fields: [parentId], references: [id])
  children    Item[]            @relation("KitItems")
  logs        InventoryLog[]
  borrowings  InventoryBorrowing[]
  audits      ItemAudit[]
}

model InventoryLog {
  id        String   @id @default(cuid())
  itemId    String
  workerId  String?
  action    String   // "Stock In", "Stock Out", "Checkout", "Return", "Adjustment"
  quantity  Int
  balance   Int      @default(0)
  notes     String?
  timestamp DateTime @default(now())

  item      Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
}

model InventoryBorrowing {
  id                String    @id @default(cuid())
  itemId            String
  quantity          Int       @default(1)
  borrowerId        String    // Worker ID (string reference)
  borrowerName      String    // Denormalized name
  borrowerEmail     String?
  borrowedAt        DateTime  @default(now())
  dueDate           DateTime?
  returnedAt        DateTime?
  status            String    @default("BORROWED")

  checkoutNotes     String?
  checkoutCondition String?
  checkoutChecklist String?   // JSON string

  returnNotes       String?
  returnCondition   String?
  returnChecklist   String?   // JSON string
  returnPhotos      String?   // JSON array string

  item              Item      @relation(fields: [itemId], references: [id])
}

model Setting {
  id   String @id
  data String // JSON string
}

model User {
  id       String @id @default(cuid())
  email    String @unique
  name     String
  role     String @default("READ_ONLY") // ADMIN, MANAGER, READ_ONLY
  password String // Hashed
}

model ItemAudit {
  id        String   @id @default(cuid())
  itemId    String?
  itemName  String
  userId    String?  // Reference to User
  userName  String?  // Denormalized name just in case user is deleted
  action    String   // "CREATED", "UPDATED", "DELETED"
  changes   String?  // JSON string
  timestamp DateTime @default(now())

  item      Item?    @relation(fields: [itemId], references: [id], onDelete: SetNull)
}
