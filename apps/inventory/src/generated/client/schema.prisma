generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?
  color       String?
  icon        String?
  isActive    Boolean @default(true)
  items       Item[]
}

model Location {
  id    String @id @default(cuid())
  name  String @unique
  items Item[]
}

model Item {
  id                 String   @id @default(cuid())
  name               String
  inventoryCode      String?  @unique
  categoryId         String
  type               String   @default("Equipment")
  stock              Int      @default(0)
  minStock           Int      @default(0)
  unit               String   @default("pcs")
  status             String   @default("Good Condition")
  statusDetails      String?
  locationId         String?
  aisle              String?
  shelf              String?
  bin                String?
  assignedTo         String?
  imageUrl           String?
  isApprovalRequired Boolean  @default(false)
  lastUpdated        DateTime @default(now()) @updatedAt
  createdAt          DateTime @default(now())

  category   Category             @relation(fields: [categoryId], references: [id])
  location   Location?            @relation(fields: [locationId], references: [id])
  logs       InventoryLog[]
  borrowings InventoryBorrowing[]
}

model InventoryLog {
  id        String   @id @default(cuid())
  itemId    String
  workerId  String? // Physical borrower/receiver
  userId    String? // System User who processed it
  action    String // "Stock In", "Stock Out", "Checkout", "Return", "Adjustment"
  quantity  Int
  balance   Int      @default(0)
  notes     String?
  timestamp DateTime @default(now())

  item Item  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id])
}

model InventoryBorrowing {
  id            String    @id @default(cuid())
  itemId        String
  quantity      Int       @default(1)
  borrowerId    String // Worker ID (string reference)
  borrowerName  String // Denormalized name
  borrowerEmail String?
  borrowedAt    DateTime  @default(now())
  dueDate       DateTime?
  returnedAt    DateTime?
  status        String    @default("BORROWED")

  checkoutNotes     String?
  checkoutCondition String?
  checkoutChecklist String? // JSON string

  returnNotes     String?
  returnCondition String?
  returnChecklist String? // JSON string
  returnPhotos    String? // JSON array string

  userId String? // System admin/manager who approved the checkout

  item Item  @relation(fields: [itemId], references: [id])
  user User? @relation(fields: [userId], references: [id])
}

model Setting {
  id   String @id
  data String // JSON string
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String // Hashed
  role      String   @default("VIEWER") // "ADMIN", "MANAGER", "VIEWER"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  logs       InventoryLog[]
  borrowings InventoryBorrowing[]
}
