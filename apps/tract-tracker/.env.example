EXPO_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# NEVER add EXPO_PUBLIC_SUPABASE_SERVICE_ROLE_KEY here — EXPO_PUBLIC_* vars are
# bundled into the client-side JS and visible to anyone who opens dev tools.
# The service-role key lives only in Supabase Edge Functions (auto-injected as
# SUPABASE_SERVICE_ROLE_KEY at runtime — see supabase/functions/*/index.ts).
