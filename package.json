{
  "name": "studio-monorepo",
  "private": true,
  "packageManager": "npm@11.6.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "build:web": "turbo run build --filter=web",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=web",
    "dev:c2s-public": "turbo run dev --filter=c2s-public",
    "build:c2s-public": "turbo run build --filter=c2s-public",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "migrate:sql": "tsx scripts/migrate.ts",
    "prepare": "husky || true",
    "apphosting:build": "sh scripts/apphosting-build.sh"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prisma": "^5.22.0",
    "tsx": "^4.21.0",
    "turbo": "^2.8.16"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.59.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
