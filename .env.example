# Supabase Connection Strings
# Replace [PASSWORD] and [PROJECT_REF] with your actual Supabase credentials.
# For Supabase, the transaction mode (6543) is usually for DATABASE_URL and session mode (5432) for direct access,
# but Prisma works best with the connection pooler.

DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase API Credentials (for the client-side/edge functions)
NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT_REF].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
