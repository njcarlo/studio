rules_version = '2';

// Studio Firebase Storage rules.
// Migration plan §8: the only bucket in scope is inventory item photos
// (path scheme `items/{itemId}/{fileName}`, cut over from Supabase Storage's
// `inventory-photos` bucket in Phase 2). Everything else stays deny-by-default.

service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }

    match /items/{itemId}/{fileName} {
      allow read: if true; // public photo URLs, matches Supabase's getPublicUrl() behavior
      allow write: if request.auth != null; // permission-gated write happens server-side (§4.2); this only requires sign-in
    }
  }
}
