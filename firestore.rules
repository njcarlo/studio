rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // WARNING: This rule allows any user, authenticated or not, to read and
      // write to any document in your database. This is highly insecure and
      // should ONLY be used for local development and debugging.
      allow read, write: if true;
    }
  }
}
