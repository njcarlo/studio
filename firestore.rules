rules_version = '2';

// Studio Firestore Security Rules — Phase 0 skeleton.
//
// Design decision (migration plan §4.2): permission checks stay server-side,
// in Next.js Server Actions / Cloud Functions using the Firebase Admin SDK
// (which bypasses these rules entirely). Client-side reads/writes through
// these rules should stay deliberately coarse — authenticated + narrow
// per-collection scoping — mirroring today's `requirePermission()` model
// instead of re-implementing the full RBAC matrix in rules language.
//
// No collections are migrated yet (Phase 3 has not started), so everything
// defaults to deny. Add one block per collection as it's cut over, rather
// than opening this up broadly ahead of the data actually landing.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Deny-by-default. Uncomment/add rules below per collection as each
    // domain is migrated (migration plan §3, §11 Phase 3).
    match /{document=**} {
      allow read, write: if false;
    }

    // Example shape for a future collection once migrated:
    // match /workers/{workerId} {
    //   allow read: if isSignedIn();
    //   allow write: if false; // writes go through Server Actions / Cloud Functions only
    // }
  }
}
