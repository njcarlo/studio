rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if the user is an admin
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && userDoc.data.roleId == 'admin';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId || isAdmin();
      allow delete: if isAdmin();
    }

    match /roles/{roleId} {
      allow read: if request.auth != null;
      // Allow write if user is admin OR if it's the initial seed.
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/roles/admin);
    }
    
    match /ministries/{ministryId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }
    
    match /locations/{locationId} {
        allow read: if request.auth != null;
        allow write: if isAdmin();
    }
    
    match /approvals/{approvalId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow write: if isAdmin();
    }

    match /rooms/{roomId} {
       allow read: if request.auth != null;
       allow write: if isAdmin();
       
       match /reservations/{reservationId} {
         allow create: if request.auth != null && request.resource.data.workerProfileId == request.auth.uid;
         allow read: if request.auth != null;
         allow update, delete: if isAdmin();
       }
    }
    
    match /attendance_records/{recordId} {
        // An owner can read their own records. An admin can read any record.
        allow read: if request.auth != null && (resource.data.workerProfileId == request.auth.uid || isAdmin());
        // Only admins can create, update, or delete attendance records.
        allow create, update, delete: if isAdmin();
    }
    
    match /mealstubs/{stubId} {
        // A user can read their own stubs. Admins can read all stubs.
        allow read: if request.auth != null && (resource.data.workerId == request.auth.uid || isAdmin());
        // A user can create a stub for themselves. Admins can create stubs.
        allow create: if request.auth != null && (request.resource.data.workerId == request.auth.uid || isAdmin());
        // Only admins can claim (update) or delete stubs.
        allow update, delete: if isAdmin();
    }

    // This rule allows the collectionGroup query for reservations to work for all authenticated users.
    match /{path=**}/reservations/{reservationId} {
        allow read: if request.auth != null;
    }

    match /scan_logs/{logId} {
      // Only admins can create or read scan logs.
      allow read, create: if isAdmin();
    }

    // Rules for dynamic workflows and their subcollections
    match /workflows/{workflowId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/workflows/default_workflow);
    }
    
    match /workflows/{workflowId}/states/{stateId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/workflows/default_workflow);
    }
    
    match /workflows/{workflowId}/transitions/{transitionId} {
      allow read: if request.auth != null;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/workflows/default_workflow);
    }
  }
}
