rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Explicitly allow read/write access to attendance records for any authenticated user.
    // This recursive wildcard covers both single-document gets and collection lists.
    match /attendance_records/{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // This rule allows any authenticated user to read and write to any document.
    // This is a permissive rule for development to prevent permission errors.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
