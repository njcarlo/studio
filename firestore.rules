/**
 * # Core Philosophy
 * This ruleset enforces a strict user-ownership model where appropriate, while providing role-based access for administrative tasks. The central concept is the `worker_profile`, which links a user's authentication UID to their data and role.
 *
 * # Data Structure
 * - `/worker_profiles/{workerId}`: Private to each user, contains their role and personal info. The `workerId` MUST match `request.auth.uid`.
 * - Top-Level Collections: Most other data (`rooms`, `ministries`, etc.) is in top-level collections for easier querying. Security within these collections often relies on checking the requesting user's role by looking up their `worker_profile`.
 *
 * # Key Security Decisions
 * - **Role-Based Access**: Most write permissions (creating rooms, approving requests, managing ministries) are restricted to users with specific roles (e.g., 'Admin', 'Super Admin'). This is enforced by the `getRole()` helper function.
 * - **No User Enumeration**: Listing the top-level `/worker_profiles` collection is disabled to protect user privacy.
 * - **Ownership via Denormalized Fields**: For user-specific documents in public collections (e.g., `reservations`, `attendance_records`), security relies on a `workerProfileId` field within the document itself.
 * - **Secure Default for Writes**: By default, writes are disallowed. Rules explicitly grant access based on ownership or role.
 *
 * # Denormalization for Authorization
 * - **User Roles**: The most critical piece of denormalized data is the `role` field within each user's `/worker_profiles/{uid}` document. The `getRole()` function uses a `get()` call to fetch this role, which is then used in rules across the system. This is a necessary trade-off for implementing role-based access control.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    function isSignedIn() {
      return request.auth != null;
    }

    function isWorkerOwner(workerId) {
      return request.auth.uid == workerId;
    }

    function isExistingDocOwner() {
      return request.auth.uid == resource.data.workerProfileId;
    }

    function isCreatingOwnDoc() {
      return request.auth.uid == request.resource.data.workerProfileId;
    }

    function getRole(uid) {
      return get(/databases/$(database)/documents/worker_profiles/$(uid)).data.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && getRole(request.auth.uid) == 'Super Admin';
    }

    function isAdmin() {
      return isSignedIn() && (getRole(request.auth.uid) == 'Admin' || isSuperAdmin());
    }

     function isMinistryHead() {
      return isSignedIn() && (getRole(request.auth.uid) == 'Ministry Head' || isAdmin());
    }


    // --------------------------------
    // Collection Rules
    // --------------------------------

    match /worker_profiles/{workerId} {
      allow get: if isSignedIn();
      allow list: if false; // Prevent user enumeration
      allow create: if isWorkerOwner(workerId);
      allow update: if isWorkerOwner(workerId) || isAdmin();
      allow delete: if isSuperAdmin();
    }

    match /approvals/{approvalId} {
      allow get, list: if isAdmin();
      allow create: if isSignedIn(); // Any signed-in user can create a request
      allow update, delete: if isAdmin(); // Only admins can approve/deny/delete
    }

    match /rooms/{roomId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();

      match /reservations/{reservationId} {
        allow get: if isExistingDocOwner() || isAdmin();
        allow list: if isSignedIn();
        allow create: if isCreatingOwnDoc();
        allow update: if isExistingDocOwner() || isAdmin();
        allow delete: if isExistingDocOwner() || isAdmin();
      }
    }

    match /mealstubs/{mealstubId} {
      allow get: if isExistingDocOwner() || isAdmin();
      allow list: if isAdmin();
      allow create: if isAdmin();
      // Allow user to claim their own stub, or admin to manage it.
      allow update: if (isExistingDocOwner() && request.resource.data.status == 'Claimed') || isAdmin();
      allow delete: if isAdmin();
    }

    match /attendance_records/{recordId} {
      allow get: if isExistingDocOwner() || isAdmin();
      allow list: if isAdmin(); // Admins can see all records
      allow create: if isCreatingOwnDoc();
      allow update, delete: if isExistingDocOwner() || isAdmin();
    }

    match /equipment/{equipmentId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    match /ministries/{ministryId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if isMinistryHead();
    }
  }
}
