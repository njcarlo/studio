rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // WORKERS: Users can read/write their OWN profile. Admins can read/write/list ANY profile.
    match /workers/{userId} {
      allow list: if request.auth.token.admin == true;
      allow read, write: if request.auth.uid == userId || request.auth.token.admin == true;
    }

    // ROLES: Any authenticated user can read roles. Admins can write.
    match /roles/{roleId} {
      allow get, list: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // APPROVALS: Admins can read/write.
    match /approvals/{approvalId} {
      allow read, write: if request.auth.token.admin == true;
    }

    // MEALSTUBS: Users can create/read their own. Admins can do anything.
    match /mealstubs/{stubId} {
      allow create: if request.auth.uid == request.resource.data.workerId;
      allow read: if request.auth.uid == get(/databases/$(database)/documents/mealstubs/$(stubId)).data.workerId || request.auth.token.admin == true;
      allow list, update: if request.auth.token.admin == true;
    }

    // SCAN LOGS: Admins can read/create.
    match /scan_logs/{logId} {
      allow read, create, list: if request.auth.token.admin == true;
    }

    // All other collections are readable/writable by any authenticated user for now.
    // This provides a baseline for development and can be tightened as needed.
    match /ministries/{ministryId} {
      allow read, write: if request.auth != null;
    }
    match /locations/{locationId} {
      allow read, write: if request.auth != null;
    }
    match /rooms/{roomId}/{document=**} {
      allow read, write: if request.auth != null;
    }
     match /attendance_records/{recordId} {
      allow read, write: if request.auth != null;
    }
  }
}
