rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // WORKERS: Users can read/write their OWN profile.
    // Admin access to other profiles is disabled here to prevent recursive rule evaluation.
    // The proper long-term solution is to use Firebase Custom Claims.
    match /workers/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // ROLES: Publicly readable. Writes require the user to have the 'admin' roleId.
    match /roles/{roleId} {
      allow get, list: if true;
      allow write: if get(/databases/$(database)/documents/workers/$(request.auth.uid)).data.roleId == 'admin';
    }

    // APPROVALS: Access is granted if the user's role has the 'manage_approvals' privilege.
    match /approvals/{approvalId} {
      allow read, write: if get(/databases/$(database)/documents/roles/$(get(/databases/$(database)/documents/workers/$(request.auth.uid)).data.roleId)).data.privileges.manage_approvals == true;
    }

    // MEALSTUBS: Users can create/read their own. Admins with privileges can update any stub.
    match /mealstubs/{stubId} {
      allow create: if request.auth.uid == request.resource.data.workerId;
      allow read: if request.auth.uid == get(/databases/$(database)/documents/mealstubs/$(stubId)).data.workerId;
      allow update: if get(/databases/$(database)/documents/roles/$(get(/databases/$(database)/documents/workers/$(request.auth.uid)).data.roleId)).data.privileges.manage_meal_stubs == true || get(/databases/$(database)/documents/roles/$(get(/databases/$(database)/documents/workers/$(request.auth.uid)).data.roleId)).data.privileges.operate_scanner == true;
    }

    // SCAN LOGS: Creation requires 'operate_scanner' privilege.
    match /scan_logs/{logId} {
      allow read, create: if get(/databases/$(database)/documents/roles/$(get(/databases/$(database)/documents/workers/$(request.auth.uid)).data.roleId)).data.privileges.operate_scanner == true;
    }

    // All other collections are readable/writable by any authenticated user for now.
    // This provides a baseline for development and can be tightened as needed.
    match /ministries/{ministryId} {
      allow read, write: if request.auth != null;
    }
    match /locations/{locationId} {
      allow read, write: if request.auth != null;
    }
    match /rooms/{roomId}/{document=**} {
      allow read, write: if request.auth != null;
    }
     match /attendance_records/{recordId} {
      allow read, write: if request.auth != null;
    }
  }
}
