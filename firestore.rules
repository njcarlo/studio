rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to get user's role document data
    function getRoleDoc() {
      // Use get() to fetch the user's document, then use its roleId to fetch the role document.
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return get(/databases/$(database)/documents/roles/$(userDoc.roleId)).data;
    }

    // Helper to check if the user's role has a specific privilege
    function hasPrivilege(privilege) {
      // Ensure the user is authenticated and check if the privilege string exists in the role's privileges array.
      return request.auth != null && privilege in getRoleDoc().privileges;
    }

    match /users/{userId} {
      // Allow any authenticated user to read user profiles.
      allow read: if request.auth != null;
      
      // Allow a user to create their own user document.
      allow create: if request.auth.uid == userId;
      
      // A user can update their own document, or an admin can.
      allow update: if request.auth.uid == userId || hasPrivilege('create_user');

      // Only admins can delete.
      allow delete: if hasPrivilege('create_user');
    }

    match /roles/{roleId} {
      // Allow any authenticated user to read roles.
      allow read: if request.auth != null;
      
      // Allow write if user has 'manage_roles' privilege OR if it's the initial seed.
      allow write: if hasPrivilege('manage_roles') || !exists(/databases/$(database)/documents/roles/admin);
    }
    
    match /approvals/{approvalId} {
        allow read, write: if hasPrivilege('create_user');
        allow create: if request.auth != null;
    }

    match /rooms/{roomId} {
       allow read: if request.auth != null;
       allow write: if hasPrivilege('edit_all');
       
       match /reservations/{reservationId} {
         allow create: if request.auth != null && request.resource.data.workerProfileId == request.auth.uid;
         allow read, update, delete: if hasPrivilege('create_user');
       }
    }
    
    // Deny all other read/write operations to all other collections by default.
  }
}
