rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Allow public scanner to read workers to verify QR payload
    match /workers/{workerId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow public scanner to read/update mealstubs
    match /mealstubs/{document=**} {
      allow read, write: if true;
    }

    // Allow public scanner to read rooms & reservations
    match /rooms/{document=**} {
      allow read: if true;
    }

    // Allow collection group queries for reservations
    match /{path=**}/reservations/{reservationId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Allow public scanner to write attendance records
    match /attendance_records/{document=**} {
      allow read, write: if true;
    }
    
    // Allow public scanner to append to scan logs
    match /scan_logs/{document=**} {
      allow read, write: if true;
    }

    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
