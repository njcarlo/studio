rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to get user's role document data
    function getRoleDoc() {
      // Use get() to fetch the user's document, then use its roleId to fetch the role document.
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return get(/databases/$(database)/documents/roles/$(userDoc.roleId)).data;
    }

    // Helper to check if the user's role has a specific privilege
    function hasPrivilege(privilege) {
      // Ensure the user is authenticated and check if the privilege string exists in the role's privileges array.
      return request.auth != null && privilege in getRoleDoc().privileges;
    }

    match /users/{userId} {
      // Allow any authenticated user to read user profiles.
      allow read: if request.auth != null;
      
      // Allow a user to create their own user document.
      allow create: if request.auth.uid == userId;
      
      // A user can update their own document, or an admin can.
      allow update: if request.auth.uid == userId || hasPrivilege('create_user');

      // Only admins can delete.
      allow delete: if hasPrivilege('create_user');
    }

    match /roles/{roleId} {
      // Allow any authenticated user to read roles.
      allow read: if request.auth != null;
      
      // Allow write if user has 'manage_roles' privilege OR if it's the initial seed.
      allow write: if hasPrivilege('manage_roles') || !exists(/databases/$(database)/documents/roles/admin);
    }
    
    match /ministries/{ministryId} {
        allow read: if request.auth != null;
        allow write: if hasPrivilege('edit_all');
    }
    
    match /locations/{locationId} {
        allow read: if request.auth != null;
        allow write: if hasPrivilege('edit_all');
    }
    
    match /approvals/{approvalId} {
        allow read, write: if hasPrivilege('create_user');
        allow create: if request.auth != null;
    }

    match /rooms/{roomId} {
       allow read: if request.auth != null;
       allow write: if hasPrivilege('edit_all');
       
       match /reservations/{reservationId} {
         allow create: if request.auth != null && request.resource.data.workerProfileId == request.auth.uid;
         // Read access for specific documents is handled by the collection group rule below.
         allow update, delete: if hasPrivilege('create_user');
       }
    }
    
    match /attendance_records/{recordId} {
        // A user can query/read their own records. An admin can read any record.
        // The query in the app MUST include a where('workerProfileId', '==', ...) clause for non-admins.
        allow read: if request.auth != null && (resource.data.workerProfileId == request.auth.uid || hasPrivilege('create_user'));
        // Only admins can create, update, or delete attendance records (e.g. via the scanner).
        allow create, update, delete: if hasPrivilege('create_user');
    }
    
    match /mealstubs/{stubId} {
        // A user can get their own stub, but not list all stubs. Admins can list/get all.
        allow get: if request.auth != null && (resource.data.workerId == request.auth.uid || hasPrivilege('create_user'));
        allow list: if hasPrivilege('create_user');
        
        // A user can create a stub for themselves. An admin can create for anyone.
        allow create: if request.auth != null && (request.resource.data.workerId == request.auth.uid || hasPrivilege('create_user'));
        
        // Only admins can claim (update) or delete stubs.
        allow update, delete: if hasPrivilege('create_user');
    }

    // This rule allows the collectionGroup query for reservations to work for all authenticated users.
    match /{path=**}/reservations/{reservationId} {
        allow read: if request.auth != null;
    }
  }
}
